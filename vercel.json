{
    "buildCommand": "npm run build",
    "outputDirectory": "frontend/dist",
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/admin(?:/.*)?",
            "dest": "/admin/index.html"
        },
        {
            "src": "/.*",
            "dest": "/index.html"
        }
    ]
}
