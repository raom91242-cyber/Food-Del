# ============================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/fooddel
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/fooddel

# Server Port
PORT=5000

# ============================================
# Cloudinary Configuration
# Get these from https://cloudinary.com/console
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Optional: Cloudinary Upload Preset
# Create one in Settings > Upload > Add upload preset
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL=http://localhost:5173

# Optional: Admin Panel URL
ADMIN_URL=http://localhost:5174

# ============================================
# JWT Configuration (if needed)
# ============================================
JWT_SECRET=your_jwt_secret_key_here

# ============================================
# Email Configuration (for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# Stripe Configuration (for payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
